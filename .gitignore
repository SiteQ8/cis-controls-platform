# .gitignore

# Operating System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Editor and IDE Files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary Files
*.tmp
*.temp
*.bak
*.cache

# Build and Distribution
dist/
build/
out/

# Dependencies (if added later)
node_modules/
bower_components/

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Testing
coverage/
.nyc_output/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# macOS
.AppleDouble
.LSOverride

# Windows
$RECYCLE.BIN/

# Linux
.directory

# Backup files
*.backup
*~.backup

# Archive files
*.zip
*.tar.gz
*.rar

# Don't ignore
!.gitkeep
